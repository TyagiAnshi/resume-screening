# Copy this to .env and fill in your key
# ─────────────────────────────────────────────
# Option A: OpenRouter (recommended – access Claude, GPT-4o, etc.)
OPENROUTER_API_KEY=sk-or-...

# Option B: OpenAI directly
# OPENAI_API_KEY=sk-...

# Model to use (OpenRouter model string or OpenAI model name)
# Examples:
#   anthropic/claude-sonnet-4-5
#   openai/gpt-4o
#   google/gemini-pro-1.5
LLM_MODEL=anthropic/claude-sonnet-4-5

# Base URL (leave as-is for OpenRouter; use https://api.openai.com/v1 for OpenAI)
LLM_BASE_URL=https://openrouter.ai/api/v1

# Output directory for ranking files and exports
OUTPUT_DIR=./outputs
